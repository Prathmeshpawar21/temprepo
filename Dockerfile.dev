FROM node:20-slim

WORKDIR /app

# Copy package files first
COPY package.json package-lock.json ./

# Delete lock file and do fresh install to get correct platform binaries
RUN rm -f package-lock.json && npm install

# Copy source (for non-volume-mount builds)
COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
